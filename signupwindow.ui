     <string notr="true">QComboBox {
    background: #1e1e1e;
    border: 2px solid #2c5aa0;
    border-radius: 6px;
    padding: 5px 8px;
    color: #ffffff;
}

QComboBox:hover {
    border-color: #1b6fd1;
}

QComboBox::drop-down {
    border: 0;
}

QComboBox QAbstractItemView {
    background: #1e1e1e;
    border: 1px solid #2c5aa0;
    selection-background-color: #2d8cf0;
    selection-color: white;
    color: white;
    padding: 4px;
}

QComboBox QAbstractItemView::item {
    padding: 6px 10px;
}</string>
